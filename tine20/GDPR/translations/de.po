msgstr "Nachricht stattdessen individuell an Listen-Mitglieder verschicken"

msgid "as it must not be contacted at all"
msgstr "weil er nicht kontaktiert werden darf"

msgid "Skip contact check if no data intended purpose has been selected"
msgstr "Kontakt-Überprüfung überspringen wenn kein Verwendungszweck ausgewählt ist"

msgid "Skip checking contact if no data intended purpose records exist"
msgstr "Kontakt-Überprüfung ohne Verwendungszweck überspringen"

msgid "as contact has not consented to this purpose"
msgstr "weil der Kontakt diesem Verwendungszweck nicht zugestimmt hat"

msgid "as consent date has expired"
msgstr "weil das Zustimmung wiederrufen wurde"

msgid "consent date is set but not yet reached"
msgstr "Das eingestellte Zustimmungsdatum ist noch nicht erreicht"

