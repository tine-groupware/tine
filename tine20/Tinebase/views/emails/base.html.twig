{% apply bootstrap_email %}
<html>
<head>
    <meta name="generator" content="bootstrapemail" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
</head>
<body class="bg-light">
    <div class="container my-10">
        <div class="my-1">
            <a class="d-inline-block" href="{{ config(constant('Tinebase_Config::BRANDING_WEBURL')) }}">
                <img src="{{ app.installation.logoContent.getBody() | data_uri }}"
                     class="max-h-16"
                     alt="Logo" />
            </a>
        </div>
        <div class="card mt-5 mb-10">
            <div class="card-body">
                {% block salutation %}
                <h5>{{ _('Hello') }}  {{ contact.getTitle() | default(_('User')) }}</h5>
                <hr>
                {% endblock %}
                <div class="space-y-3">
                {% block body %}
                {% endblock %}
                </div>
            </div>
        </div>
        {% include 'Tinebase/views/footer.html.twig' %}
    </div>
</body>
</html>
{% endapply %}